generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                   String                @id @default(cuid())
  name                 String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  code                 String                @unique
  email                String?
  phone                String?
  isActive             Boolean               @default(true)
  platformCharges      PlatformCharge[]
  registrationRequests RegistrationRequest[]
  routes               Route[]
  stages               Stage[]
  users                User[]
  vehicles             Vehicle[]
  vehicleOwners        VehicleOwner[]
  drivers              Driver[]
  conductors           Conductor[]
  stageMarshals        StageMarshal[]
  vehicleCrews         VehicleCrew[]
}

model RegistrationRequest {
  id String @id @default(cuid())

  tenantId String
  userId   String? @unique

  firstName  String
  lastName   String
  email      String @unique
  phone      String
  nationalId String

  role   UserRole
  status RegistrationStatus @default(PENDING)

  // Submitted documents
  licenceUrl        String?
  badgeUrl          String?
  goodConductUrl    String?
  profileImageUrl   String?
  vehicleLogbookUrl String?

  approvedById String?
  approvedAt   DateTime?

  rejectedById    String?
  rejectedAt      DateTime?
  rejectionReason String?

  user User? @relation(fields: [userId], references: [id])

  approvedBy User? @relation("RegistrationApprovedBy", fields: [approvedById], references: [id])
  rejectedBy User? @relation("RegistrationRejectedBy", fields: [rejectedById], references: [id])

  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordSetupToken {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  token String @unique

  expiresAt DateTime

  used Boolean @default(false)

  createdAt DateTime @default(now())
}

model User {
  id                  String               @id @default(cuid())
  tenantId            String?
  name                String
  email               String               @unique
  password            String?
  role                UserRole
  profile             UserProfile?
  vehicleOwner        VehicleOwner?
  driver              Driver?
  conductor           Conductor?
  stageMarshal        StageMarshal?
  accountStatus       AccountStatus        @default(PENDING_SETUP)
  setupTokens         PasswordSetupToken[]
  resetTokens         PasswordResetToken[]
  lastLoginAt         DateTime?
  failedLoginAttempts Int                  @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenant              Tenant?              @relation(fields: [tenantId], references: [id])

  registrationRequests RegistrationRequest[]
  approvedRequests     RegistrationRequest[] @relation("RegistrationApprovedBy")
  rejectedRequests     RegistrationRequest[] @relation("RegistrationRejectedBy")
}

model RolePolicy {
  id String @id @default(cuid())

  actorRole UserRole // who is performing action
  fromRole  UserRole // current role of target
  toRole    UserRole // new role being assigned

  action String @default("ROLE_CHANGE")

  createdAt DateTime @default(now())
}

model UserProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  firstName  String
  lastName   String
  phone      String
  nationalId String

  profileImageUrl String?

  goodConductUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  token String @unique

  expiresAt DateTime

  used Boolean @default(false)

  createdAt DateTime @default(now())
}

model Route {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name String

  origin      String
  destination String

  stages     Stage[]
  dispatches Dispatch[]

  estimatedDistance Float?
  estimatedDuration Int?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
}

model Stage {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  routeId String
  route   Route  @relation(fields: [routeId], references: [id])

  name String

  stageNumber Int

  arrivals   Arrival[]
  dispatches Dispatch[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Prevent duplicate stage numbers in the same route
  @@unique([routeId, stageNumber])
  // Prevent duplicate stage names in the same route
  @@unique([routeId, name])
  @@index([tenantId])
  @@index([routeId])
}

model VehicleOwner {
  id       String @id @default(cuid())
  tenantId String

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  vehicles Vehicle[]

  vehicleLogbookUrl String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Driver {
  id String @id @default(cuid())

  userId   String @unique
  tenantId String

  licenceUrl String?

  vehicleCrews VehicleCrew[]

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conductor {
  id String @id @default(cuid())

  userId   String @unique
  tenantId String

  badgeUrl String?

  vehicleCrews VehicleCrew[]

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StageMarshal {
  id String @id @default(cuid())

  userId   String @unique
  tenantId String

  assignedStage String?

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id       String @id @default(cuid())
  tenantId String

  ownerId String
  owner   VehicleOwner @relation(fields: [ownerId], references: [id])

  logbookUrl         String?
  registrationNumber String
  plateNumber        String
  capacity           Int?

  status VehicleStatus @default(PENDING_APPROVAL)

  vehicleCrews     VehicleCrew[]
  arrivals         Arrival[]
  dispatches       Dispatch[]
  inspectionDate   DateTime?
  inspectionNotes  String?
  inspectionById   String?
  approvedById     String?
  approvedAt       DateTime?
  suspendedById    String?
  suspendedAt      DateTime?
  suspensionReason String?
  rejectionReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model VehicleCrew {
  id String @id @default(cuid())

  tenantId String

  vehicleId   String
  driverId    String
  conductorId String?

  vehicle   Vehicle    @relation(fields: [vehicleId], references: [id])
  driver    Driver     @relation(fields: [driverId], references: [id])
  conductor Conductor? @relation(fields: [conductorId], references: [id])

  status CrewAssignmentStatus @default(ACTIVE)

  assignedAt DateTime  @default(now())
  endedAt    DateTime?

  assignedById String?
  endedById    String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([conductorId])
  @@index([status])
}

model Arrival {
  id          String        @id @default(cuid())
  vehicleId   String
  stageId     String
  arrivalTime DateTime      @default(now())
  status      ArrivalStatus @default(ARRIVED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  stage       Stage         @relation(fields: [stageId], references: [id])
  vehicle     Vehicle       @relation(fields: [vehicleId], references: [id])
}

model Dispatch {
  id               String          @id @default(cuid())
  vehicleId        String
  routeId          String
  stageId          String
  dispatchTime     DateTime        @default(now())
  fare             Decimal         @db.Decimal(10, 2)
  stageFee         Decimal         @db.Decimal(10, 2)
  paymentConfirmed Boolean         @default(false)
  expectedRevenue  Decimal         @db.Decimal(12, 2)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  route            Route           @relation(fields: [routeId], references: [id])
  stage            Stage           @relation(fields: [stageId], references: [id])
  vehicle          Vehicle         @relation(fields: [vehicleId], references: [id])
  platformCharge   PlatformCharge?
}

model PlatformCharge {
  id             String    @id @default(cuid())
  tenantId       String
  dispatchId     String    @unique
  commissionRate Decimal   @db.Decimal(5, 2)
  amount         Decimal   @db.Decimal(12, 2)
  paid           Boolean   @default(false)
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  dispatch       Dispatch  @relation(fields: [dispatchId], references: [id])
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
}

enum UserRole {
  SUPER_ADMIN
  SACCO_ADMIN
  DIRECTOR
  MANAGER
  STAGE_MARSHAL
  VEHICLE_OWNER
  DRIVER
  CONDUCTOR
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AccountStatus {
  PENDING_SETUP
  ACTIVE
  SUSPENDED
}

enum VehicleStatus {
  PENDING_APPROVAL
  INSPECTION_SCHEDULED
  INSPECTED
  APPROVED
  ACTIVE
  SUSPENDED
  REJECTED
}

enum CrewAssignmentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ArrivalStatus {
  ARRIVED
  WAITING
  DISPATCHED
}
