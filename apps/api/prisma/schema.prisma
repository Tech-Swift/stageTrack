generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                   String                @id @default(cuid())
  name                 String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  code                 String                @unique
  email                String?
  phone                String?
  isActive             Boolean               @default(true)
  platformCharges      PlatformCharge[]
  registrationRequests RegistrationRequest[]
  routes               Route[]
  stages               Stage[]
  users                User[]
  vehicles             Vehicle[]
  vehicleOwners        VehicleOwner[]
}

model RegistrationRequest {
  id String @id @default(cuid())

  tenantId String
  userId   String? @unique

  firstName  String
  lastName   String
  email      String @unique
  phone      String
  nationalId String

  role   UserRole
  status RegistrationStatus @default(PENDING)

  // Submitted documents
  licenceUrl        String?
  badgeUrl          String?
  goodConductUrl    String?
  profileImageUrl   String?
  vehicleLogbookUrl String?

  approvedById String?
  approvedAt   DateTime?

  rejectedById    String?
  rejectedAt      DateTime?
  rejectionReason String?

  user User? @relation(fields: [userId], references: [id])

  approvedBy User? @relation("RegistrationApprovedBy", fields: [approvedById], references: [id])
  rejectedBy User? @relation("RegistrationRejectedBy", fields: [rejectedById], references: [id])

  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordSetupToken {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  token String @unique

  expiresAt DateTime

  used Boolean @default(false)

  createdAt DateTime @default(now())
}

model User {
  id                  String               @id @default(cuid())
  tenantId            String?
  name                String
  email               String               @unique
  password            String?
  role                UserRole
  profile             UserProfile?
  accountStatus       AccountStatus        @default(PENDING_SETUP)
  setupTokens         PasswordSetupToken[]
  resetTokens         PasswordResetToken[]
  lastLoginAt         DateTime?
  failedLoginAttempts Int                  @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenant              Tenant?              @relation(fields: [tenantId], references: [id])

  registrationRequests RegistrationRequest[]
  approvedRequests     RegistrationRequest[] @relation("RegistrationApprovedBy")
  rejectedRequests     RegistrationRequest[] @relation("RegistrationRejectedBy")
}

model UserProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  firstName  String
  lastName   String
  phone      String
  nationalId String

  profileImageUrl String?

  goodConductUrl String?

  licenceUrl String?

  badgeUrl String?

  vehicleLogbookUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  token String @unique

  expiresAt DateTime

  used Boolean @default(false)

  createdAt DateTime @default(now())
}

model Route {
  id          String     @id @default(cuid())
  tenantId    String
  name        String
  origin      String
  destination String
  dispatches  Dispatch[]
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  stages      Stage[]
}

model Stage {
  id         String     @id @default(cuid())
  tenantId   String
  routeId    String
  name       String
  arrivals   Arrival[]
  dispatches Dispatch[]
  route      Route      @relation(fields: [routeId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
}

model VehicleOwner {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  phone     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  vehicles  Vehicle[]
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
}

model Vehicle {
  id                 String       @id @default(cuid())
  tenantId           String
  vehicleOwnerId     String
  registrationNumber String       @unique
  plateSuffix        String
  capacity           Int
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  arrivals           Arrival[]
  dispatches         Dispatch[]
  tenant             Tenant       @relation(fields: [tenantId], references: [id])
  vehicleOwner       VehicleOwner @relation(fields: [vehicleOwnerId], references: [id])

  @@index([plateSuffix])
}

model Arrival {
  id          String        @id @default(cuid())
  vehicleId   String
  stageId     String
  arrivalTime DateTime      @default(now())
  status      ArrivalStatus @default(ARRIVED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  stage       Stage         @relation(fields: [stageId], references: [id])
  vehicle     Vehicle       @relation(fields: [vehicleId], references: [id])
}

model Dispatch {
  id               String          @id @default(cuid())
  vehicleId        String
  routeId          String
  stageId          String
  dispatchTime     DateTime        @default(now())
  fare             Decimal         @db.Decimal(10, 2)
  stageFee         Decimal         @db.Decimal(10, 2)
  paymentConfirmed Boolean         @default(false)
  expectedRevenue  Decimal         @db.Decimal(12, 2)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  route            Route           @relation(fields: [routeId], references: [id])
  stage            Stage           @relation(fields: [stageId], references: [id])
  vehicle          Vehicle         @relation(fields: [vehicleId], references: [id])
  platformCharge   PlatformCharge?
}

model PlatformCharge {
  id             String    @id @default(cuid())
  tenantId       String
  dispatchId     String    @unique
  commissionRate Decimal   @db.Decimal(5, 2)
  amount         Decimal   @db.Decimal(12, 2)
  paid           Boolean   @default(false)
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  dispatch       Dispatch  @relation(fields: [dispatchId], references: [id])
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
}

enum UserRole {
  SUPER_ADMIN
  SACCO_ADMIN
  DIRECTOR
  MANAGER
  STAGE_MARSHAL
  VEHICLE_OWNER
  DRIVER
  CONDUCTOR
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AccountStatus {
  PENDING_SETUP
  ACTIVE
  SUSPENDED
}

enum ArrivalStatus {
  ARRIVED
  WAITING
  DISPATCHED
}
