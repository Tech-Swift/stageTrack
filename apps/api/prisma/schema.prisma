generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                   String                @id @default(cuid())
  name                 String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  code                 String                @unique
  email                String?
  phone                String?
  isActive             Boolean               @default(true)
  conductors           Conductor[]
  drivers              Driver[]
  platformCharges      PlatformCharge[]
  registrationRequests RegistrationRequest[]
  routes               Route[]
  stages               Stage[]
  stageAssignment      StageAssignment[]
  stageMarshals        StageMarshal[]
  branding             TenantBranding?
  users                User[]
  vehicles             Vehicle[]
  vehicleCrews         VehicleCrew[]
  vehicleOwners        VehicleOwner[]
}

model TenantBranding {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  displayName     String?
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String   @default("#2563EB")
  secondaryColor  String?
  accentColor     String?
  backgroundColor String?
  textColor       String?
  buttonRadius    Int      @default(12)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model RegistrationRequest {
  id                String             @id @default(cuid())
  tenantId          String
  firstName         String
  lastName          String
  phone             String
  nationalId        String
  role              UserRole
  licenceUrl        String?
  badgeUrl          String?
  status            RegistrationStatus @default(PENDING)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  email             String             @unique
  goodConductUrl    String?
  profileImageUrl   String?
  rejectionReason   String?
  vehicleLogbookUrl String?
  approvedAt        DateTime?
  approvedById      String?
  rejectedAt        DateTime?
  rejectedById      String?
  userId            String?            @unique
  approvedBy        User?              @relation("RegistrationApprovedBy", fields: [approvedById], references: [id])
  rejectedBy        User?              @relation("RegistrationRejectedBy", fields: [rejectedById], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  user              User?              @relation(fields: [userId], references: [id])
}

model PasswordSetupToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model User {
  id                   String                @id @default(cuid())
  tenantId             String?
  name                 String
  email                String                @unique
  password             String?
  role                 UserRole
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  accountStatus        AccountStatus         @default(PENDING_SETUP)
  failedLoginAttempts  Int                   @default(0)
  lastLoginAt          DateTime?
  lockedUntil          DateTime?
  conductor            Conductor?
  driver               Driver?
  resetTokens          PasswordResetToken[]
  setupTokens          PasswordSetupToken?
  approvedRequests     RegistrationRequest[] @relation("RegistrationApprovedBy")
  rejectedRequests     RegistrationRequest[] @relation("RegistrationRejectedBy")
  registrationRequests RegistrationRequest?
  StageAssignment      StageAssignment[]
  stageMarshal         StageMarshal?
  tenant               Tenant?               @relation(fields: [tenantId], references: [id])
  profile              UserProfile?
  vehicleOwner         VehicleOwner?
}

model RolePolicy {
  id        String   @id @default(cuid())
  actorRole UserRole
  fromRole  UserRole
  toRole    UserRole
  action    String   @default("ROLE_CHANGE")
  createdAt DateTime @default(now())
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  firstName       String
  lastName        String
  phone           String
  nationalId      String
  profileImageUrl String?
  goodConductUrl  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Route {
  id                String     @id @default(cuid())
  tenantId          String
  name              String
  origin            String
  destination       String
  createdAt         DateTime   @default(now())
  estimatedDistance Float?
  estimatedDuration Int?
  isActive          Boolean    @default(true)
  updatedAt         DateTime   @updatedAt
  dispatches        Dispatch[]
  tenant            Tenant     @relation(fields: [tenantId], references: [id])
  stages            Stage[]

  @@unique([tenantId, name])
}

model Stage {
  id            String              @id @default(cuid())
  tenantId      String
  routeId       String
  name          String
  createdAt     DateTime            @default(now())
  isActive      Boolean             @default(true)
  stageNumber   Int
  updatedAt     DateTime            @updatedAt
  arrivals      Arrival[]
  dispatches    Dispatch[]
  route         Route               @relation(fields: [routeId], references: [id])
  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  assignments   StageAssignment[]
  stageQueues   StageQueue[]
  queueCounters StageQueueCounter[]

  @@unique([routeId, stageNumber])
  @@unique([routeId, name])
  @@index([tenantId])
  @@index([routeId])
}

model VehicleOwner {
  id                String    @id @default(cuid())
  tenantId          String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  userId            String    @unique
  vehicleLogbookUrl String?
  vehicles          Vehicle[]
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  user              User      @relation(fields: [userId], references: [id])
}

model Driver {
  id           String        @id @default(cuid())
  userId       String        @unique
  tenantId     String
  licenceUrl   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  vehicleCrews VehicleCrew[]
}

model Conductor {
  id           String        @id @default(cuid())
  userId       String        @unique
  tenantId     String
  badgeUrl     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  vehicleCrews VehicleCrew[]
}

model StageMarshal {
  id            String   @id @default(cuid())
  userId        String   @unique
  tenantId      String
  assignedStage String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  user          User     @relation(fields: [userId], references: [id])
}

model StageAssignment {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String
  stageId     String

  startDate   DateTime
  endDate     DateTime?

  // Optional daily shift hours
  shiftStart  String?   @db.VarChar(5) // HH:mm
  shiftEnd    String?   @db.VarChar(5) // HH:mm

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  user         User      @relation(fields: [userId], references: [id])
  stage         Stage      @relation(fields: [stageId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([stageId])
  @@index([userId, stageId])
  @@index([startDate])
  @@index([endDate])
}

model Vehicle {
  id                 String        @id @default(cuid())
  tenantId           String
  registrationNumber String
  capacity           Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  approvedAt         DateTime?
  approvedById       String?
  ownerId            String
  plateNumber        String
  rejectionReason    String?
  status             VehicleStatus @default(PENDING_APPROVAL)
  inspectionById     String?
  inspectionDate     DateTime?
  inspectionNotes    String?
  suspendedAt        DateTime?
  suspendedById      String?
  suspensionReason   String?
  logbookUrl         String?
  arrivals           Arrival[]
  dispatches         Dispatch[]
  stageQueues        StageQueue[]
  owner              VehicleOwner  @relation(fields: [ownerId], references: [id])
  tenant             Tenant        @relation(fields: [tenantId], references: [id])
  vehicleCrews       VehicleCrew[]
}

model VehicleCrew {
  id           String               @id @default(cuid())
  tenantId     String
  vehicleId    String
  driverId     String
  conductorId  String?
  status       CrewAssignmentStatus @default(ACTIVE)
  assignedAt   DateTime             @default(now())
  assignedById String?
  notes        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  endedById    String?
  endedAt      DateTime?
  conductor    Conductor?           @relation(fields: [conductorId], references: [id])
  driver       Driver               @relation(fields: [driverId], references: [id])
  tenant       Tenant               @relation(fields: [tenantId], references: [id])
  vehicle      Vehicle              @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([conductorId])
  @@index([status])
}

model Arrival {
  id           String      @id @default(cuid())
  vehicleId    String
  stageId      String
  arrivalTime  DateTime    @default(now())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  queueEntryId String?     @unique
  stage        Stage       @relation(fields: [stageId], references: [id])
  vehicle      Vehicle     @relation(fields: [vehicleId], references: [id])
  queueEntry   StageQueue?
}

model StageQueue {
  id             String      @id @default(cuid())
  stageId        String
  vehicleId      String
  arrivalId      String      @unique
  position       Int?
  status         QueueStatus @default(QUEUED)
  enqueuedAt     DateTime    @default(now())
  dispatchedAt   DateTime?
  sequenceNumber Int
  arrival        Arrival     @relation(fields: [arrivalId], references: [id])
  stage          Stage       @relation(fields: [stageId], references: [id])
  vehicle        Vehicle     @relation(fields: [vehicleId], references: [id])

  @@unique([vehicleId, status])
  @@index([stageId, position])
}

model StageQueueCounter {
  stageId   String
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
  date      DateTime @db.Timestamp(3)
  id        String   @id @default(cuid())
  stage     Stage    @relation(fields: [stageId], references: [id])

  @@unique([stageId, date])
}

model Dispatch {
  id               String          @id @default(cuid())
  vehicleId        String
  routeId          String
  stageId          String
  dispatchTime     DateTime        @default(now())
  fare             Decimal         @db.Decimal(10, 2)
  stageFee         Decimal         @db.Decimal(10, 2)
  paymentConfirmed Boolean         @default(false)
  expectedRevenue  Decimal         @db.Decimal(12, 2)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  route            Route           @relation(fields: [routeId], references: [id])
  stage            Stage           @relation(fields: [stageId], references: [id])
  vehicle          Vehicle         @relation(fields: [vehicleId], references: [id])
  platformCharge   PlatformCharge?
}

model PlatformCharge {
  id             String    @id @default(cuid())
  tenantId       String
  dispatchId     String    @unique
  commissionRate Decimal   @db.Decimal(5, 2)
  amount         Decimal   @db.Decimal(12, 2)
  paid           Boolean   @default(false)
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  dispatch       Dispatch  @relation(fields: [dispatchId], references: [id])
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
}

enum UserRole {
  SUPER_ADMIN
  SACCO_ADMIN
  STAGE_MARSHAL
  DIRECTOR
  MANAGER
  DRIVER
  CONDUCTOR
  VEHICLE_OWNER
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AccountStatus {
  PENDING_SETUP
  ACTIVE
  SUSPENDED
}

enum VehicleStatus {
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  SUSPENDED
  REJECTED
  INSPECTION_SCHEDULED
  INSPECTED
}

enum CrewAssignmentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum QueueStatus {
  QUEUED
  SKIPPED
  REMOVED
  LOADING
  DISPATCHED
  READY_TO_DISPATCH
}
